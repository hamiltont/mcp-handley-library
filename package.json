{
  "name": "mcp-handley-library",
  "version": "1.0.0",
  "description": "MCP server for searching the Handley Regional Library catalog",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http",
    "mcp:inspect": "npx @modelcontextprotocol/inspector node /Users/hamiltont/Programming/mcp-handley-library/dist/index.js"
  },
  "keywords": [
    "mcp",
    "library",
    "catalog"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "express": "^4.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
